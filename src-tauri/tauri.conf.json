{
  "productName": "Studio Magnate",
  "version": "../package.json",
  "identifier": "com.studiomagnate.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": { "csp": null },
    "windows": [
      {
        "label": "main",
        "title": "Studio Magnate",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["../public/favicon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "offlineInstaller", "silent": true },
      "nsis": { "installMode": "perMachine", "displayLanguageSelector": true },
      "wix": { "language": "en-US", "upgradeCode": "9a3c0de9-3c76-4c67-97da-1ad1cbf58c95a0" }
    }
  }
}
