{
  "productName": "Studio Magnate",
  "version": "../package.json",
  "identifier": "com.studiomagnate.studiomagnate",
  "build": {
    "beforeDevCommand": "node scripts/prepare-tauri-icons.mjs && npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "node scripts/prepare-tauri-icons.mjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost 'self' https://fonts.googleapis.com https://fonts.gstatic.com http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https://*.supabase.co wss://*.supabase.co",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' data: https://fonts.gstatic.com",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Studio Magnate",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "appimage",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon-alt.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "9a3c0de9-3c76-4c67-97da-1ad1cbf58c95"
      }
    }
  }
}
