# Copy this file to .env and fill in values.
# Do not commit .env.

# No environment variables are required for the base game.

# Optional: enable Online League (Supabase Realtime)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Optional: Steam DLC store integration (Streaming Wars)
# VITE_STEAM_STREAMING_WARS_DLC_APP_ID=
